{
  "name": "petanque-master",
  "private": true,
  "version": "0.1.0",
  "description": "Petanque Master - Jeu web 2D style Pokemon avec combats de petanque",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:debug": "npx playwright test --debug",
    "test:visual": "npx playwright test visual-regression",
    "test:perf": "npx playwright test performance",
    "test:stress": "npx playwright test stress",
    "test:health": "npx playwright test health",
    "test:update-snapshots": "npx playwright test visual-regression --update-snapshots",
    "test:report": "npx playwright show-report",
    "test:all": "vitest run && npx playwright test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "phaser": "^4.0.0-rc.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "jimp": "^1.6.0",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "terser": "^5.46.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
