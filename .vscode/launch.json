{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev Server + Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8080",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "dev",
      "sourceMaps": true
    },
    {
      "name": "Attach Chrome (dev deja lance)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true
    }
  ]
}
